{
  "name": "emb3r",
  "version": "1.0.0",
  "description": "Local LLM desktop app powered by node-llama-cpp",
  "author": "Ziyan",
  "type": "module",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test-ai": "node test-ai.js",
    "dist": "electron-builder"
  },
  "dependencies": {
    "node-llama-cpp": "^3.19.0"
  },
  "allowScripts": {
    "node-llama-cpp@3.19.0": true
  },
  "devDependencies": {
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "io.github.frenchiiifries.emb3r",
    "productName": "emb3r",
    "asar": true,
    "asarUnpack": [
      "**/node_modules/node-llama-cpp/**"
    ],
    "files": [
      "main.js",
      "preload.cjs",
      "src/**/*",
      "!models/**"
    ],
    "win": {
      "target": ["nsis"]
    },
    "mac": {
      "target": ["dmg", "zip"],
      "category": "public.app-category.productivity",
      "identity": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
